<Window x:Name="Winget_Lab" x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Winget_Lab"
        mc:Ignorable="d"
        Title="Winget Lab" Height="950" Width="1285" Icon="/Lab.png" WindowStartupLocation="CenterScreen" Background="#FF3A3A3A">

    <Window.Resources>
        <!-- Filter Button Style -->
        <Style x:Key="FilterButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3F3F3F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Filter Icon -->
                                <TextBlock Grid.Column="0" 
                                           Text="⚡" 
                                           FontSize="14" 
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,6,0"/>

                                <!-- Filter Text -->
                                <TextBlock x:Name="FilterText"
                                           Grid.Column="1" 
                                           Text="Filter Source" 
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>

                                <!-- Dropdown Arrow -->
                                <Path Grid.Column="2" 
                                      Data="M 0 0 L 4 4 L 8 0 Z" 
                                      Fill="{TemplateBinding Foreground}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3D3D3D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF4F4F4F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF1D1D1D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3D3D3D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Popup Menu Item Style -->
        <Style x:Key="FilterMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Checkmark (if checked) -->
                                <TextBlock x:Name="CheckMark"
                                           Grid.Column="0"
                                           Text="✓"
                                           Foreground="#FF0078D4"
                                           Visibility="Collapsed"
                                           Margin="0,0,8,0"/>

                                <!-- Menu Item Text -->
                                <ContentPresenter Grid.Column="1" 
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top Menu Bar - Docked to Top -->
        <Menu x:Name="MainMenu" DockPanel.Dock="Top" Background="#BF000000" BorderBrush="Transparent" BorderThickness="0" Foreground="#FFFAFAFA">
            <Menu.Resources>
                <!-- Style for top-level menu items -->
                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Foreground" Value="#FFFAFAFA"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Opacity" Value="0.75"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type MenuItem}">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                        BorderBrush="Transparent" BorderThickness="0"
                                        Opacity="{TemplateBinding Opacity}">
                                    <Grid>
                                        <ContentPresenter ContentSource="Header" Margin="10,5,10,5" 
                                                          VerticalAlignment="Center"/>
                                        <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}"
                                               AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                            <Border Background="#BF000000" BorderThickness="0" BorderBrush="Transparent">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3FFFFFFF"/>
                                        <Setter TargetName="Border" Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3FFFFFFF"/>
                                        <Setter TargetName="Border" Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- Style for submenu items -->
                <Style TargetType="{x:Type MenuItem}" x:Key="SubMenuItemStyle">
                    <Setter Property="Foreground" Value="#FFFAFAFA"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Opacity" Value="0.75"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type MenuItem}">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                        BorderBrush="Transparent" BorderThickness="0" Padding="20,6,20,6"
                                        Opacity="{TemplateBinding Opacity}">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#3FFFFFFF"/>
                                        <Setter TargetName="Border" Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Menu.Resources>
            <MenuItem Header="File" Background="Transparent">
                <MenuItem Header="New" x:Name="NewMenuItem" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Open" x:Name="OpenMenuItem" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>
            <MenuItem Header="Tools" Background="Transparent">
                <MenuItem Header="Get Current List" x:Name="GetCurrentListMenuItem" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Capture Start Menu" x:Name="CaptureStartMenuMenuItem" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Grid -->
        <Grid>
            <!-- Search Section -->
            <Border Height="50" Background="Transparent" CornerRadius="25"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0" Width="980" BorderBrush="#FF3B31B5" BorderThickness="1,1,1,0">
                <Border Background="#B2FFFFFF" CornerRadius="25" Padding="5" BorderBrush="#FF2B52D9">
                    <Grid>
                        <!-- Search Icon -->
                        <TextBlock Text="🔍" FontSize="20" Foreground="#666666"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" 
                                   Margin="15,0,0,0"/>

                        <!-- Search TextBox -->
                        <TextBox x:Name="SearchTextBox" 
                                 Background="Transparent" BorderThickness="0" Foreground="#333333"
                                 VerticalAlignment="Center" FontSize="16" Margin="50,0,140,0" GotFocus="SearchTextBox_GotFocus">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="0"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Search Button -->
                        <Border Width="120" Height="36" Background="#BF000000" CornerRadius="18"
                                HorizontalAlignment="Left" Margin="845,2,0,1">
                            <Button x:Name="SearchButton" Content="Search" 
                                    Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand"
                                    FontSize="14" FontWeight="SemiBold">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3FFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#5FFFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <!-- Search Results ListBox -->
            <Border x:Name="Results" Height="224" Background="#BF000000" CornerRadius="5" 
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,75,0,0" Width="1151">
                <Grid>
                    <TextBlock x:Name="HeaderText" Text="Name                                                                            Id                                                 Version                                                        Match                                                                     Source"
                               Foreground="#FFCCCCCC"
                               VerticalAlignment="Top" Margin="10,5,0,0" FontWeight="Bold"/>

                    <!-- ListBox with rounded corners -->
                    <Border CornerRadius="5" Margin="5,25,5,40" Background="Transparent">
                        <ListBox x:Name="SearchResultsListBox" d:ItemsSource="{d:SampleData ItemCount=10}"
                                 Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FFFAFAFA"/>
                                    <Setter Property="Padding" Value="2"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3FFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1FFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </Border>

                    <!-- Filter Button with Popup -->
                    <Grid x:Name="SourceFilterPanel" 
                          HorizontalAlignment="Left" 
                          VerticalAlignment="Bottom" 
                          Margin="10,0,0,5"
                          Visibility="Collapsed">
                        <ToggleButton x:Name="SourceFilterButton"
                                      Style="{StaticResource FilterButtonStyle}"
                                      Height="28"
                                      MinWidth="120"/>

                        <Popup x:Name="SourceFilterPopup"
                               PlacementTarget="{Binding ElementName=SourceFilterButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="#FF2D2D2D" 
                                    BorderBrush="#FF3F3F3F" 
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="0"
                                    MinWidth="120">
                                <StackPanel x:Name="SourceFilterMenu"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Hidden ComboBox for compatibility -->
                    <ComboBox x:Name="SourceFilterComboBox" Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Selected Items (Manifest) ListBoxes -->
            <Border x:Name="SelectedPackage" Width="1151" Height="224" Background="#BF000000" CornerRadius="5"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,304,0,0">
                <Grid>
                    <TextBlock Text="Selected Packages" Foreground="#FFCCCCCC" FontWeight="Bold"
                               VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <!-- ListBox with rounded corners -->
                    <Border CornerRadius="5" Margin="10,35,10,40" Background="Transparent">
                        <ListBox x:Name="SelectedNamesListBox" d:ItemsSource="{d:SampleData ItemCount=5}"
                                 Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#FFFAFAFA"/>
                                    <Setter Property="Padding" Value="2"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3FFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1FFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Resources>
                        </ListBox>
                    </Border>

                    <!-- Remove Button -->
                    <Border Width="120" Height="28" Background="#BF000000" CornerRadius="5"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,5">
                        <Button x:Name="RemoveButton" Content="Remove Selected" 
                                Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3FFF0000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#5FFF0000"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>
                </Grid>
            </Border>

            <!-- Hidden ListBox for IDs -->
            <ListBox x:Name="SelectedIDsListBox" Visibility="Collapsed"/>

            <!-- Build Options -->
            <Border x:Name="Build" Width="250" Height="227" Background="#BF000000" CornerRadius="5" Margin="518,533,518,120">
                <StackPanel Margin="15">
                    <TextBlock Text="Build Options" Foreground="#FFCCCCCC" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="Project Name:" Foreground="#FFFAFAFA" Margin="0,0,0,5"/>
                    <TextBox x:Name="FilenameTextBox" Background="#33FFFFFF" BorderThickness="1" 
                             BorderBrush="#FF555555" Foreground="#FFFAFAFA" Height="25" Margin="0,0,0,10" Width="200"/>
                    <CheckBox x:Name="DeleteLinksCheckBox" Content="Delete Desktop Shortcuts" 
                              Foreground="#FFFAFAFA" Margin="0,5"/>
                    <CheckBox x:Name="CaptureStartMenuCheckBox" Content="Replicate this Start Menu layout" 
                              Foreground="#FFFAFAFA" Margin="0,5"/>

                    <!-- Build Button -->
                    <Border Width="120" Height="35" Background="#BF000000" CornerRadius="5" 
                            Margin="0,20,0,0" HorizontalAlignment="Center">
                        <Button x:Name="BuildButton" Content="Build Script" 
                                Background="Transparent" BorderThickness="0" Foreground="#FFFAFAFA" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3FFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#5FFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer with Progress Panel and Activity Light -->
            <Border Width="1100" Height="86" Background="#BF000000" 
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                    Margin="0,0,0,0" CornerRadius="5,5,0,0">
                <Canvas x:Name="FooterGrid" Width="1100" Height="86">
                    <!-- Heading Text -->
                    <TextBlock x:Name="HeadingTextBlock"
                               Foreground="#FFCCCCCC"
                               FontSize="22"
                               Canvas.Left="31"
                               Canvas.Top="16"/>

                    <!-- Copyright Text -->
                    <TextBlock x:Name="CopyrightTextBlock"
                               Foreground="#CCC"
                               TextWrapping="Wrap"
                               Canvas.Left="31"
                               Canvas.Top="50"
                               Width="700"/>

                    <!-- Winget Activity Light -->
                    <Ellipse x:Name="WingetActivityLight"
                             Width="18" Height="18"
                             Fill="#333"
                             Stroke="#555"
                             StrokeThickness="1"
                             Cursor="Hand"
                             Canvas.Right="20"
                             Canvas.Top="34"
                             ToolTip="Winget Activity"/>

                    <!-- Progress Panel -->
                    <StackPanel x:Name="ProgressPanel"
                                Orientation="Vertical"
                                Canvas.Right="50"
                                Canvas.Top="16"
                                Width="230">
                        <TextBlock x:Name="ProgressText"
                                   FontSize="22"
                                   Foreground="#FFE2E2E2"
                                   TextAlignment="Right"
                                   TextTrimming="None"
                                   TextWrapping="NoWrap"
                                   Width="230"/>

                        <TextBlock x:Name="ProgressTextDetail"
                                   Margin="0,4,0,0"
                                   Foreground="#FFE2E2E2"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Width="230"/>
                    </StackPanel>
                </Canvas>
            </Border>
        </Grid>
    </DockPanel>
</Window>